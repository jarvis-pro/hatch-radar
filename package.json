{
  "name": "hatch-radar",
  "version": "0.1.0",
  "private": true,
  "description": "定时抓取 Reddit 等社区，AI 提炼用户痛点与产品机会（pnpm workspace monorepo）",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pnpm --filter @hatch-radar/server dev",
    "start": "pnpm --filter @hatch-radar/server start",
    "worker": "pnpm --filter @hatch-radar/server worker",
    "test": "pnpm --filter @hatch-radar/server test",
    "dev:web": "pnpm --filter @hatch-radar/web dev",
    "build:web": "pnpm --filter @hatch-radar/web build",
    "start:web": "pnpm --filter @hatch-radar/web start",
    "dev:mobile": "pnpm --filter @hatch-radar/mobile start",
    "db:generate": "pnpm --filter @hatch-radar/db db:generate",
    "db:migrate": "pnpm --filter @hatch-radar/db db:migrate",
    "db:push": "pnpm --filter @hatch-radar/db db:push",
    "db:studio": "pnpm --filter @hatch-radar/db db:studio",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write apps packages",
    "format:check": "prettier --check apps packages"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "catalog:",
    "typescript-eslint": "^8.61.0"
  }
}
