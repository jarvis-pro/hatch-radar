{
  "name": "hatch-radar",
  "version": "0.1.0",
  "private": true,
  "description": "定时抓取 Reddit 等社区，AI 提炼用户痛点与产品机会（pnpm workspace monorepo）",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pnpm --filter @hatch-radar/server dev",
    "build": "pnpm --filter @hatch-radar/server build",
    "start": "pnpm --filter @hatch-radar/server start",
    "db:migrate": "pnpm --filter @hatch-radar/server db:migrate",
    "insights": "pnpm --filter @hatch-radar/server insights",
    "analyze": "pnpm --filter @hatch-radar/server analyze",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write apps packages",
    "format:check": "prettier --check apps packages"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
