{
  "name": "@hatch-radar/kernel",
  "version": "0.1.0",
  "private": true,
  "description": "框架无关的领域基座（零内部依赖）：错误 / 日志 / 时间 / 加解密 / env 校验 / 网关协议(含 Dispatcher 接口)。被各能力包与 api/worker 两端复用。",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hatch-radar/config": "workspace:*",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.8"
  }
}
