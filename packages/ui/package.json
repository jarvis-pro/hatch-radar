{
  "name": "@hatch-radar/ui",
  "version": "0.1.0",
  "private": true,
  "description": "PC 端共享 UI 库：shadcn/ui + Tailwind v4（TS 源码形态分发，由消费方 Next.js 应用转译；仅限 Web/PC 子项目，React Native 勿引）",
  "type": "module",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./components/*": "./src/components/*.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@hatch-radar/config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tailwindcss": "^4.3.0",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "catalog:",
    "radix-ui": "^1.5.0",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.78.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "catalog:",
    "sonner": "^2.0.7",
    "tailwind-merge": "catalog:",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "catalog:"
  }
}
