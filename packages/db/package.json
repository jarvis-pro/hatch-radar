{
  "name": "@hatch-radar/db",
  "version": "0.1.0",
  "private": true,
  "description": "PostgreSQL 主存储层：Prisma schema + 连接工厂（@prisma/adapter-pg）+ PG⇄域类型映射（server 读写、web 只读共用；不进 mobile）",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:pull": "prisma db pull",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hatch-radar/config": "workspace:*",
    "@hatch-radar/kernel": "workspace:*",
    "@hatch-radar/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "prisma": "^7.8.0",
    "typescript": "catalog:"
  }
}
