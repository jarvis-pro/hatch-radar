# ============================================================================
# 工作区根级共享配置（api + worker + prisma 迁移共用）
# ----------------------------------------------------------------------------
# 加载：apps/api、apps/worker 的 start/dev 脚本均带 --env-file-if-exists=../../.env，
#       packages/db 的 prisma.config.ts 也加载本文件——三者由此同源。
# 优先级：OS env  >  各 app 本地 .env  >  本文件  >  代码内置默认值。
# 边界：只放「两个进程都读、且应当一致」的配置；进程专属项见 apps/*/.env.example。
# 用法：cp .env.example .env，填好下面「必填」两项即可启动。
# ============================================================================

# ─── 必填 ───────────────────────────────────────────────────────────────────

# PostgreSQL 主存储（api / worker 连同一库，prisma 迁移也指向它）；
# 本地 docker-compose 默认值可直连，生产换托管 PG 只改此串
DATABASE_URL=postgres://radar:radar@localhost:47432/hatch_radar

# 模型密钥加密主密钥（AES-256-GCM），生成：openssl rand -hex 32
# 留空则禁用 AI 分析（仅爬 HackerNews/RSS）；上线后更换会使库中已加密密钥无法解密
SETTINGS_SECRET=

# ─── 可选调优（共享；均有默认值，取消注释即同时覆盖两端）─────────────────────

# 日志级别 trace/debug/info/warn/error/fatal（api / worker 共用同一 logger）
# LOG_LEVEL=info

# api 的 HTTP 端口：api 监听它（发 /api + 同源 SPA + /ws/worker 网关），
# worker 也读它推导默认网关 ws://localhost:<HTTP_PORT>/ws/worker。
# 集中在此，改端口时两端自动对齐；worker 跨机部署则改用其 GATEWAY_URL。
# HTTP_PORT=47878

# PG 连接池上限（api / worker 同读）；不设时各自推导默认：api=10、worker=并发+5。
# 需要分别调时，在对应 apps/*/.env 里单独设以覆盖本值。
# DATABASE_POOL_MAX=10
