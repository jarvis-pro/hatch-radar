# ============================================================================
# MidwayJS 平替版 .env —— cp .env.example .env 后填写
# 与 NestJS 版（apps/server）共用同一个 PostgreSQL 与同一把加密主密钥，仅 HTTP_PORT 不同。
# ============================================================================

# PostgreSQL 主存储：必须与 NestJS 版指向同一个库（共享数据）。
DATABASE_URL=postgres://radar:radar@localhost:47432/hatch_radar

# 模型密钥加密主密钥（AES-256-GCM）：必须与 NestJS 版完全一致，否则库里已加密的模型 Key 无法解密。
# 留空也能启动（仅爬取 HackerNews / RSS，AI 分析不可用）。生成：openssl rand -hex 32
SETTINGS_SECRET=

# 关键：本平替版监听端口。NestJS 版默认 47878；这里设 47879，便于 A/B 端口并排对比。
HTTP_PORT=47879

# ── 按需 / 调优（均有默认值，一般不用动；语义与 NestJS 版一致）──────────────
# 首个超级管理员种子（仅空库时创建，幂等）；空库初始化时填写
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_PASSWORD=
# 是否同进程跑分析 worker，默认 true；设 false 拆到独立进程（pnpm worker）
# WORKER_IN_PROCESS=true
# 独立 worker 连 gateway 的地址；不设则自动推导 ws://localhost:<HTTP_PORT>/ws/worker
# GATEWAY_URL=
# 分析 worker 并发数，默认 2
# WORKER_CONCURRENCY=2
# PG 连接池上限，默认 max(10, WORKER_CONCURRENCY+5)
# DATABASE_POOL_MAX=10
# 日志级别，默认 info
# LOG_LEVEL=info
