{
  "name": "@hatch-radar/server",
  "version": "0.1.0",
  "private": true,
  "description": "工作台后端：爬取 + AI 分析 + 调度（密钥只在此进程，绝不下发到 web / mobile）",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "sh scripts/build.sh",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/schema.ts",
    "insights": "tsx src/cli.ts",
    "analyze": "tsx src/analyze-once.ts",
    "serve": "tsx src/serve.ts",
    "export:batch": "tsx src/export-batch.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@hatch-radar/shared": "workspace:*",
    "better-sqlite3": "catalog:",
    "dotenv": "^17.4.2",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rss-parser": "^3.13.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "esbuild": "^0.25.0",
    "tsx": "^4.22.4",
    "typescript": "catalog:"
  }
}
