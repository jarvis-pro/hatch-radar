{
  "name": "@hatch-radar/server",
  "version": "0.1.0",
  "private": true,
  "description": "工作台后端（NestJS + PostgreSQL）：爬取 + AI 分析 + 调度（密钥只在此进程，绝不下发到 web / mobile）",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @hatch-radar/db db:migrate && node --env-file-if-exists=.env --watch --import @swc-node/register/esm-register src/main.ts",
    "start": "pnpm --filter @hatch-radar/db db:migrate && node --env-file-if-exists=.env --import @swc-node/register/esm-register src/main.ts",
    "worker": "node --env-file-if-exists=.env --import @swc-node/register/esm-register src/worker-main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@hatch-radar/auth": "workspace:*",
    "@hatch-radar/config": "workspace:*",
    "@hatch-radar/db": "workspace:*",
    "@hatch-radar/shared": "workspace:*",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "better-sqlite3": "catalog:",
    "nestjs-pino": "^4.6.1",
    "pg": "catalog:",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rss-parser": "^3.13.0",
    "rxjs": "^7.8.2",
    "ws": "^8.21.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.26",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@types/better-sqlite3": "catalog:",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@types/ws": "^8.18.1",
    "typescript": "catalog:",
    "vitest": "^4.1.8"
  }
}
