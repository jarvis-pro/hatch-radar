# ============================================================================
# 必填：cp .env.example .env 后，先填好这一段再启动
# ============================================================================

# PostgreSQL 主存储（server 读写 + web 只读共用同一个库）。
# 本地用 docker compose up -d db 起 PG，下面默认值可直接连；生产换托管 PG 改此行即可。
DATABASE_URL=postgres://radar:radar@localhost:47432/hatch_radar

# 模型密钥加密主密钥（AES-256-GCM）。在 Web 设置页(/settings)保存模型 API Key 前必须先设它，
# 否则存不了任何模型、也就跑不了 AI 分析（本项目核心）。生成一个高熵随机串填到 = 后面：
#   openssl rand -hex 32
# 说明：留空也能启动（仅爬取 HackerNews / RSS，AI 分析不可用），去配模型时会明确报错提示补这项；
#       上线后更换此值会导致库里已加密的密钥无法解密，需在设置页重填。
SETTINGS_SECRET=

# ============================================================================
# AI 模型：要跑分析就得有一个可用模型。两种配置方式，二选一即可：
#   (A) 推荐：在 Web 设置页(/settings)添加模型——多模型可切换、密钥加密入库（需上面的 SETTINGS_SECRET）。
#   (B) 启动兜底：在下面设 AI_PROVIDER + 对应 KEY，启动时一次性迁移入库并设为 active（同样需要 SETTINGS_SECRET）。
# 走方式 (A) 的话，下面这一整段都不用填。
# ============================================================================

# 启动兜底使用的分析方式：anthropic | openai | deepseek
# AI_PROVIDER=anthropic

# ── Anthropic（AI_PROVIDER=anthropic 时必填 KEY）──
# ANTHROPIC_API_KEY=your_anthropic_api_key
# 模型默认 claude-opus-4-8（输入 $5 / 输出 $25 每百万 token）；
# 大批量、成本敏感可换 claude-sonnet-4-6（$3/$15）或 claude-haiku-4-5（$1/$5）
# ANTHROPIC_MODEL=claude-opus-4-8

# ── OpenAI / ChatGPT（AI_PROVIDER=openai 时必填 KEY；原生 json_schema strict 结构化输出）──
# 在 https://platform.openai.com 获取 API Key，定价见官网
# OPENAI_API_KEY=your_openai_api_key
# 模型默认 gpt-4o（支持结构化输出；可换 gpt-4o-mini 降成本）
# OPENAI_MODEL=gpt-4o
# API 基地址，默认 https://api.openai.com/v1（自建兼容网关可改）
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── DeepSeek（AI_PROVIDER=deepseek 时必填 KEY；OpenAI 兼容接口）──
# 在 https://platform.deepseek.com 获取 API Key，定价见官网
# DEEPSEEK_API_KEY=your_deepseek_api_key
# 模型默认 deepseek-chat（支持 JSON 输出模式；不建议 deepseek-reasoner）
# DEEPSEEK_MODEL=deepseek-chat
# API 基地址，默认 https://api.deepseek.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============================================================================
# 按需启用（不填即关闭对应能力，不影响启动）
# ============================================================================

# Reddit OAuth：不填则跳过 Reddit 抓取（HackerNews 与 RSS 无需凭据，始终启用）。
# 五个字段要填就一起填——CLIENT_ID + CLIENT_SECRET 一旦出现，其余三个即变必填。
# 在 https://www.reddit.com/prefs/apps 注册 script 类型应用获取。
# REDDIT_CLIENT_ID=your_client_id
# REDDIT_CLIENT_SECRET=your_client_secret
# REDDIT_USERNAME=your_reddit_username
# REDDIT_PASSWORD=your_reddit_password
# REDDIT_USER_AGENT=hatch-radar/1.0 (by /u/your_reddit_username)

# 导出 / 同步 HTTP 服务（随主进程自动启动，绑定 0.0.0.0 供移动端拉取批次）的访问令牌。
# 设置后导出 / 同步接口要求 Authorization: Bearer <token>；不设则局域网内免鉴权
# （健康检查 /api/health 始终免鉴权）。
# API_TOKEN=

# ============================================================================
# 可选调优（均有默认值，一般不用动）
# ============================================================================

# 导出 HTTP 服务监听端口，默认 47878
# HTTP_PORT=47878

# 每轮（每小时）送入 AI 分析的帖子数上限，默认 20
# ANALYZE_BATCH_SIZE=20

# 日志级别，默认 info（trace/debug/info/warn/error/fatal）。
# 日志统一打到 stdout：开发为彩色可读格式，生产（NODE_ENV=production）为结构化 JSON，
# 持久化/轮转交给 Docker 的 logging driver（见 docker-compose.yml），应用本身不落盘。
# LOG_LEVEL=info

# 是否在主进程内同进程跑分析 worker，默认 true。
# 设为 false 可把 worker 拆到独立进程（pnpm worker）按 PG 行锁认领，单独扩容。
# 注意：HTTP + 定时调度的主进程须单实例（cron 无分布式锁，多开会重复抓取）；可水平扩的只有 worker 这层。
# WORKER_IN_PROCESS=true

# worker 进程连接 gateway 的 WebSocket 地址（仅独立 worker 进程 WORKER_IN_PROCESS=false 时需要）；
# 不设则自动推导为 ws://localhost:<HTTP_PORT>/ws/worker
# GATEWAY_URL=

# 分析 worker 池参数（默认值适配单机；扩容主要调 WORKER_CONCURRENCY）。独立 worker 进程同样读这些值。
# WORKER_CONCURRENCY=2          # 并发认领数
# WORKER_JOB_TIMEOUT_MS=600000  # 单 job 硬超时（毫秒）
# WORKER_STALE_SECONDS=300      # running 心跳超时回收阈值（秒，须 > 内部心跳 15s）

# PG 连接池上限，默认 max(10, WORKER_CONCURRENCY+5)；调大并发时池会自动随之放大，
# 一般无需手动设。仅在需要精确控制单进程连接总数时显式设置。
# DATABASE_POOL_MAX=10
