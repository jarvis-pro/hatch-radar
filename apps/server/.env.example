# ============================================================================
# 必填：cp .env.example .env 填好这段再启动
# ============================================================================

# PostgreSQL 主存储（server 唯一读写）；本地 docker-compose 默认值可直连，生产换托管 PG
DATABASE_URL=postgres://radar:radar@localhost:47432/hatch_radar

# 模型密钥加密主密钥（AES-256-GCM），生成：openssl rand -hex 32
# 留空则禁用 AI 分析（仅爬 HackerNews/RSS）；上线后更换会使库中已加密密钥无法解密
SETTINGS_SECRET=

# ============================================================================
# 按需启用（不填即关闭，不影响启动）
# ============================================================================

# 首个超管种子（仅空库首启创建，幂等）；新部署务必设，否则无账户可登录，首登强制改密
# SUPER_ADMIN_EMAIL=you@example.com
# SUPER_ADMIN_PASSWORD=change-me-at-least-8-chars

# SPA 静态产物目录，默认 ../web/dist；不存在则跳过托管（开发期走 Vite proxy）
# WEB_DIST_DIR=

# ============================================================================
# 可选调优（均有默认值，一般不用动）
# 注：分析批次 / 会话时长 / job 超时 / 僵死回收阈值等运行期参数已移入 DB（首启播种、Web 设置页可改），不再走 env
# ============================================================================

# HTTP 监听端口（同时发 /api 与同源托管 SPA）
# HTTP_PORT=47878

# 日志级别 trace/debug/info/warn/error/fatal
# LOG_LEVEL=info

# 同进程跑分析 worker；设 false 拆独立进程（pnpm worker）扩容。主进程（HTTP+cron）须单实例，仅 worker 可水平扩
# WORKER_IN_PROCESS=true

# 独立 worker（WORKER_IN_PROCESS=false）连 gateway 的 WS 地址；默认 ws://localhost:<HTTP_PORT>/ws/worker
# GATEWAY_URL=

# 分析 worker 并发认领数（改后须重启 worker；影响连接池下限）
# WORKER_CONCURRENCY=2

# PG 连接池上限，默认 max(10, WORKER_CONCURRENCY+5)，一般无需手动设
# DATABASE_POOL_MAX=10
