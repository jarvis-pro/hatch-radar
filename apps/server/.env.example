# ============================================================================
# 必填：cp .env.example .env 后填好这一段再启动
# ============================================================================

# PostgreSQL 主存储（server 读写 + web 只读共用）。本地 docker compose up -d db 起 PG，
# 下面默认值可直接连；生产换托管 PG 改此行即可。
DATABASE_URL=postgres://radar:radar@localhost:47432/hatch_radar

# 模型密钥加密主密钥（AES-256-GCM），在 Web 设置页保存模型 API Key 前必须先设。
# 生成：openssl rand -hex 32
# 留空也能启动（仅爬 HackerNews / RSS，AI 分析不可用）；上线后更换会导致库里已加密的密钥无法解密。
SETTINGS_SECRET=

# ============================================================================
# 按需启用（不填即关闭，不影响启动）
# ============================================================================

# 导出 / 同步 HTTP 服务的访问令牌。设置后接口要求 Authorization: Bearer <token>；
# 不设则局域网内免鉴权（/api/health 始终免鉴权）。
# API_TOKEN=

# ============================================================================
# 可选调优（均有默认值，一般不用动）
# ============================================================================

# 导出 HTTP 服务监听端口
# HTTP_PORT=47878

# 每轮（每小时）送入 AI 分析的帖子数上限
# ANALYZE_BATCH_SIZE=20

# 日志级别（trace/debug/info/warn/error/fatal）。统一打到 stdout：开发彩色、生产 JSON。
# LOG_LEVEL=info

# 是否在主进程内同进程跑分析 worker。设为 false 可把 worker 拆到独立进程（pnpm worker）单独扩容。
# 注意：HTTP + 定时调度的主进程须单实例（cron 无分布式锁）；可水平扩的只有 worker 层。
# WORKER_IN_PROCESS=true

# 独立 worker 进程（WORKER_IN_PROCESS=false）连接 gateway 的 WebSocket 地址；
# 不设则推导为 ws://localhost:<HTTP_PORT>/ws/worker
# GATEWAY_URL=

# 分析 worker 池参数（默认适配单机；扩容主要调 WORKER_CONCURRENCY）
# WORKER_CONCURRENCY=2          # 并发认领数
# WORKER_JOB_TIMEOUT_MS=600000  # 单 job 硬超时（毫秒）
# WORKER_STALE_SECONDS=300      # running 心跳超时回收阈值（秒，须 > 内部心跳 15s）

# PG 连接池上限，默认 max(10, WORKER_CONCURRENCY+5)，调大并发时自动放大，一般无需手动设。
# DATABASE_POOL_MAX=10
