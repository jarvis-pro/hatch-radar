# 数据库（PostgreSQL 主存储）
# 本地用 docker-compose 起 PG：  docker compose up -d db
# 生产换托管 PG 只需改此连接串；server 读写 + web 只读共用同一个库。
DATABASE_URL=postgres://radar:radar@localhost:47432/hatch_radar

# Reddit OAuth（可选）
# 不填则跳过 Reddit 抓取；HackerNews 与 RSS 无需凭据，始终启用
# 在 https://www.reddit.com/prefs/apps 注册 script 类型应用
# REDDIT_CLIENT_ID=your_client_id
# REDDIT_CLIENT_SECRET=your_client_secret
# REDDIT_USERNAME=your_reddit_username
# REDDIT_PASSWORD=your_reddit_password
# REDDIT_USER_AGENT=hatch-radar/1.0 (by /u/your_reddit_username)

# ===== AI 分析方式 =====
# 推荐在 Web 设置页（/settings）配置模型：多模型可选、密钥加密入库、可选用 active。
# 下面的 AI_PROVIDER + KEY 仅作「启动兜底」——设了会在启动时一次性迁移入库并设为 active：
#   AI_PROVIDER=anthropic + ANTHROPIC_API_KEY  → 使用 Anthropic
#   AI_PROVIDER=openai    + OPENAI_API_KEY     → 使用 OpenAI（ChatGPT）
#   AI_PROVIDER=deepseek  + DEEPSEEK_API_KEY   → 使用 DeepSeek
# 不设则不从 env 派生模型（在设置页配置即可）；迁移入库需同时配 SETTINGS_SECRET。
# AI_PROVIDER=anthropic

# ── Anthropic（AI_PROVIDER=anthropic 时启用）──
# ANTHROPIC_API_KEY=your_anthropic_api_key
# 分析模型，默认 claude-opus-4-8（输入 $5 / 输出 $25 每百万 token）
# 大批量、成本敏感时可改用 claude-sonnet-4-6（$3/$15）或 claude-haiku-4-5（$1/$5）
# ANTHROPIC_MODEL=claude-opus-4-8

# ── OpenAI / ChatGPT（AI_PROVIDER=openai 时启用，原生 json_schema strict 结构化输出）──
# 在 https://platform.openai.com 获取 API Key，定价见官网
# OPENAI_API_KEY=your_openai_api_key
# 模型默认 gpt-4o（支持结构化输出；可改 gpt-4o-mini 降成本）
# OPENAI_MODEL=gpt-4o
# API 基地址，默认 https://api.openai.com/v1（自建兼容网关可改）
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── DeepSeek（AI_PROVIDER=deepseek 时启用，OpenAI 兼容接口）──
# 在 https://platform.deepseek.com 获取 API Key，定价见官网
# DEEPSEEK_API_KEY=your_deepseek_api_key
# 模型默认 deepseek-chat（支持 JSON 输出模式；不建议使用 deepseek-reasoner）
# DEEPSEEK_MODEL=deepseek-chat
# API 基地址，默认 https://api.deepseek.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===== 模型密钥加密（设置页配置模型时必填）=====
# 在 web 设置页填写的模型 API Key 会用此主密钥 AES-256-GCM 加密入库；
# web 即便直读同一个 PostgreSQL 库也只见密文。生成一个高强度随机串即可：
#   openssl rand -hex 32
# 注意：更换此值会导致已入库的密钥无法解密，需在设置页重填。
# SETTINGS_SECRET=

# ===== 导出服务（局域网 HTTP，供移动端拉取批次）=====
# 随主进程自动启动（pnpm dev / start）
# 监听端口，绑定 0.0.0.0，默认 47878
# HTTP_PORT=47878
# 可选访问令牌；设置后 /api/export/* 接口要求 Authorization: Bearer <token>
# 不设置则局域网内免鉴权（健康检查 /api/health 始终免鉴权）
# API_TOKEN=

# ===== 以下为可选配置 =====

# 每轮（每小时）送入 AI 分析的帖子数上限，默认 20
# ANALYZE_BATCH_SIZE=20

# 日志目录，默认 ./logs；按天轮转，命名格式 YYYY-MM-DD.log
# LOG_DIR=./logs

# 是否在主进程内同进程跑分析 worker，默认 true。
# 设为 false 可把 worker 拆到独立进程（pnpm worker）按 PG 行锁认领，单独扩容。
# 注意：HTTP + 定时调度的主进程须单实例（cron 无分布式锁，多开会重复抓取）；可水平扩的只有 worker 这层。
# WORKER_IN_PROCESS=true
