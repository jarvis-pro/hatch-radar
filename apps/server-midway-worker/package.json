{
  "name": "@hatch-radar/server-midway-worker",
  "version": "0.1.0",
  "private": true,
  "description": "工作台分析 worker（数据面）：纯队列消费者,经 WS 连 API 网关认领 job、跑 AI 分析、写回。领域逻辑全在 @hatch-radar/core——worker 不需要任何 Web 框架,可独立横向扩。",
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch --import @swc-node/register/esm-register src/worker-main.ts",
    "start": "node --env-file-if-exists=.env --import @swc-node/register/esm-register src/worker-main.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hatch-radar/core": "workspace:*",
    "@hatch-radar/db": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@hatch-radar/config": "workspace:*",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@types/node": "catalog:",
    "@types/ws": "^8.18.1",
    "typescript": "catalog:"
  }
}
