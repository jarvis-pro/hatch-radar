{
  "name": "@hatch-radar/api",
  "version": "0.1.0",
  "private": true,
  "description": "工作台后端（NestJS + PostgreSQL，单进程）：HTTP API(/api) + 鉴权权威 + @Cron 调度 + 内嵌任务执行。web SPA 单独部署，本进程不托管静态产物。领域逻辑在 src/domain，框架无关能力代码内联在 src/lib（kernel/db/crawler/analysis/auth）+ Prisma 基建在本 app。密钥只在此进程，绝不下发到 web / mobile。",
  "type": "module",
  "scripts": {
    "dev": "prisma migrate deploy && node --env-file-if-exists=.env --watch --import @swc-node/register/esm-register src/main.ts",
    "start": "prisma migrate deploy && node --env-file-if-exists=.env --import @swc-node/register/esm-register src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "db:studio": "prisma studio",
    "backfill:hn-decode": "node --env-file-if-exists=.env --import @swc-node/register/esm-register scripts/backfill-hn-decode.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.177",
    "@anthropic-ai/sdk": "^0.104.1",
    "@hatch-radar/config": "workspace:*",
    "@hatch-radar/shared": "workspace:*",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scalar/nestjs-api-reference": "^1.2.5",
    "cron-parser": "^5.6.0",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "pg": "catalog:",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rss-parser": "^3.13.0",
    "rxjs": "^7.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.26",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "prisma": "^7.8.0",
    "typescript": "catalog:",
    "vitest": "^4.1.8"
  }
}
