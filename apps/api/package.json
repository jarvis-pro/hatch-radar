{
  "name": "@hatch-radar/api",
  "version": "0.1.0",
  "private": true,
  "description": "工作台后端 API（NestJS + PostgreSQL，单进程）：HTTP + 鉴权 + 调度 + 内嵌任务执行 + 同源托管 web SPA。领域逻辑组装在 src/domain（复用 kernel/db/crawler/analysis 能力包）。密钥只在此进程，绝不下发到 web / mobile。",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @hatch-radar/db db:migrate && node --env-file-if-exists=../../.env --env-file-if-exists=.env --watch --import @swc-node/register/esm-register src/main.ts",
    "start": "pnpm --filter @hatch-radar/db db:migrate && node --env-file-if-exists=../../.env --env-file-if-exists=.env --import @swc-node/register/esm-register src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "backfill:hn-decode": "node --env-file-if-exists=../../.env --env-file-if-exists=.env --import @swc-node/register/esm-register scripts/backfill-hn-decode.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.177",
    "@anthropic-ai/sdk": "^0.104.1",
    "@hatch-radar/config": "workspace:*",
    "@hatch-radar/db": "workspace:*",
    "@hatch-radar/kernel": "workspace:*",
    "@hatch-radar/shared": "workspace:*",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.3",
    "better-sqlite3": "catalog:",
    "cron-parser": "^5.6.0",
    "nestjs-pino": "^4.6.1",
    "reflect-metadata": "^0.2.2",
    "rss-parser": "^3.13.0",
    "rxjs": "^7.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.26",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@types/better-sqlite3": "catalog:",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.8"
  }
}
