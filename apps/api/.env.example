# ============================================================================
# 后端环境变量 —— 单进程后端的唯一 env 文件
# ----------------------------------------------------------------------------
# 加载：dev/start 脚本带 --env-file-if-exists=.env 读本文件；prisma.config.ts
#       （迁移 CLI）也加载它——运行期与迁移由此同源。已无工作区根 .env。
# 优先级：OS env  >  本文件  >  代码内置默认值。空串 KEY= 视为未设置（留空不崩启动）。
# 容器化（docker compose --profile full）：compose 经 env_file 读本文件注入容器。
# 用法：cp .env.example .env，填好下面「必填」即可启动。
# ============================================================================

# ─── 必填 ───────────────────────────────────────────────────────────────────

# PostgreSQL 主存储（prisma 迁移也指向它）；本地 docker-compose 默认值可直连，
# 生产换托管 PG 只改此串
DATABASE_URL=postgres://radar:radar@localhost:47432/hatch_radar

# ─── 按需启用（不填即关闭，不影响启动）──────────────────────────────────────

# 模型 / 连接器密钥加密主密钥（AES-256-GCM），生成：openssl rand -hex 32
# 留空只能跑 claude_cli 订阅模式 + 公开源（HN/RSS）；用 API-Key 模型 / Azure 翻译 /
# Reddit 等需凭据的源都必须配它——容器化与生产部署几乎都得填
# 坑：上线后更换会使库中已加密的密钥 / 凭据无法解密
SETTINGS_SECRET=

# 首个超管种子（仅空库首启创建，幂等）；新部署务必设，否则无账户可登录，首登强制改密
# SUPER_ADMIN_EMAIL=you@example.com
# SUPER_ADMIN_PASSWORD=change-me-at-least-8-chars

# ─── 可选调优（均有默认值，取消注释即覆盖）──────────────────────────────────

# 日志级别 trace/debug/info/warn/error/fatal，默认 info
# LOG_LEVEL=info

# HTTP 监听端口，默认 47878（发 /api；绑定 0.0.0.0 供局域网移动端访问）
# HTTP_PORT=47878

# 内嵌执行器并发认领数，默认 20（单进程归一后承接旧 worker 的并发上限）
# WORKER_CONCURRENCY=20

# PG 连接池上限；不设时推导默认 max(10, WORKER_CONCURRENCY + 5)
# DATABASE_POOL_MAX=10

# 注：分析批次 / 会话时长 / job 超时 / 僵死回收阈值等运行期参数已移入 DB
#     （首启播种、Web 设置页可改），不再走 env。
