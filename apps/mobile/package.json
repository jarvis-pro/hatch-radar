{
  "name": "@hatch-radar/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "RN 离线伴侣 App（Expo）：本地 SQLite + 导入批次 + 离线人工研判（无 AI、无密钥）",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "APP_VARIANT=development expo run:android --device",
    "ios": "APP_VARIANT=development expo run:ios --device",
    "prebuild": "APP_VARIANT=development expo prebuild --clean",
    "prebuild:prod": "expo prebuild --clean",
    "ios:release": "expo run:ios --device --configuration Release",
    "android:release": "expo run:android --device --variant release",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hatch-radar/shared": "workspace:*",
    "@rn-primitives/label": "^1.4.0",
    "@rn-primitives/separator": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@rn-primitives/toggle": "^1.4.0",
    "@rn-primitives/toggle-group": "^1.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~56.0.11",
    "expo-build-properties": "~56.0.18",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "lucide-react-native": "^1.17.0",
    "nativewind": "^4.2.5",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-css-interop": "0.2.5",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/react": "~19.2.17",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3"
  }
}
