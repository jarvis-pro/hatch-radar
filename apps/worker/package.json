{
  "name": "@hatch-radar/worker",
  "version": "0.1.0",
  "private": true,
  "description": "工作台数据面 worker（NestJS standalone context）：经 PG 队列认领分析 job、WS 连 api 网关、跑 AI 分析写回。无 HTTP / 无调度，可独立横向扩 N 实例。",
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch --import @swc-node/register/esm-register src/main.ts",
    "start": "node --env-file-if-exists=.env --import @swc-node/register/esm-register src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hatch-radar/analysis": "workspace:*",
    "@hatch-radar/config": "workspace:*",
    "@hatch-radar/db": "workspace:*",
    "@hatch-radar/kernel": "workspace:*",
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "nestjs-pino": "^4.6.1",
    "reflect-metadata": "^0.2.2",
    "ws": "^8.21.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@types/node": "catalog:",
    "@types/ws": "^8.18.1",
    "typescript": "catalog:"
  }
}
