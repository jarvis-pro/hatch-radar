# ============================================================================
# 数据面 worker 进程（apps/worker）配置：cp .env.example .env
# 与 api 共用同一 AppEnv 校验；单机部署可直接复用 api 的 .env，多机扩容时各 worker 单独配置。
# ============================================================================

# PostgreSQL 主存储（与 api 连同一库，按 PG 行锁 FOR UPDATE SKIP LOCKED 认领 job）
DATABASE_URL=postgres://radar:radar@localhost:47432/hatch_radar

# 模型密钥加密主密钥（须与 api 一致，否则无法解密库中模型密钥）；openssl rand -hex 32
SETTINGS_SECRET=

# 连 api 网关的 WebSocket 地址；默认 ws://localhost:<HTTP_PORT>/ws/worker，跨机扩容时填 api 主机地址
# GATEWAY_URL=ws://localhost:47878/ws/worker

# 并发认领数（改后须重启 worker；影响连接池下限）
# WORKER_CONCURRENCY=2

# 日志级别 trace/debug/info/warn/error/fatal
# LOG_LEVEL=info

# PG 连接池上限，默认 max(10, WORKER_CONCURRENCY+5)
# DATABASE_POOL_MAX=10
